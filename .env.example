# =============================================================
# PhishGuard AI — Environment Variables Reference
# Copy this file to .env and fill in the values.
# =============================================================

# --- APP / SERVER ---------------------------------------------------
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- DATABASE -------------------------------------------------------
# PostgreSQL connection string
# Supabase format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=

# --- SUPABASE -------------------------------------------------------
# Supabase project URL — https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase service role key (server-side only — NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=
# Supabase publishable key (if applicable)
SUPABASE_PUBLISHABLE_KEY=

# --- AUTH / JWT -----------------------------------------------------
# Secret key used to sign JWT tokens — use a long random string in prod
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
# JWT token expiry duration
JWT_EXPIRES_IN=7d
# Session secret for express-session (if used)
SESSION_SECRET=

# --- FRONTEND -------------------------------------------------------
# Public-facing app URL (e.g. https://phishguard.vercel.app)
NEXT_PUBLIC_APP_URL=
# API base URL for frontend requests (e.g. https://api.phishguard.app)
NEXT_PUBLIC_API_URL=

# --- THREAT INTELLIGENCE APIs ---------------------------------------
# VirusTotal API key — https://www.virustotal.com/gui/my-apikey
# Leave empty to run with internal risk engine only
VIRUSTOTAL_API_KEY=

# Google Safe Browsing API key — https://console.cloud.google.com/
# Enable the "Safe Browsing API" in your Google Cloud project
# Leave empty to run with internal risk engine only
GOOGLE_SAFE_BROWSING_API_KEY=

# AbuseIPDB API key — https://www.abuseipdb.com/account/api
# Leave empty to run with internal risk engine only
ABUSEIPDB_API_KEY=

# --- AI PROVIDERS ---------------------------------------------------
# OpenAI API key — https://platform.openai.com/api-keys
# Required for AI explanations, assistant chat, and screenshot analysis
OPENAI_API_KEY=

# Google Gemini API key (optional, for future AI provider support)
GEMINI_API_KEY=

# OCR API key (optional, for OCR-based text extraction)
OCR_API_KEY=

# --- EMAIL / SMTP ---------------------------------------------------
# SMTP configuration for sending alert/report emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- SECURITY -------------------------------------------------------
# Encryption key for sensitive data at rest
ENCRYPTION_KEY=
