# ============================================================
# PhishGuard — Git Ignore
# ============================================================

# Compiled output
dist/
tmp/
out-tsc/
*.tsbuildinfo

# Dependencies
node_modules/

# Environment variables (secrets — NEVER commit these)
.env
.env.local
.env.production
.env.*.local

# IDE / Editor
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/

# OS
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/

# Legacy Replit files
.cache/
.local/
.replit
.replitignore
replit.md

# Legacy monorepo files
pnpm-lock.yaml
pnpm-workspace.yaml
tsconfig.base.json

# Attached assets (legacy)
attached_assets/
