# =============================================================
# PhishGuard Backend — Environment Variables
# =============================================================

# --- APP / SERVER ---------------------------------------------------
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- DATABASE -------------------------------------------------------
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# --- SUPABASE -------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AUTH / JWT -----------------------------------------------------
JWT_SECRET=change-this-to-random-64-bytes
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-this-to-random-64-bytes

# --- FRONTEND URL (for CORS) ----------------------------------------
FRONTEND_URL=https://phishguard.vercel.app

# --- THREAT INTELLIGENCE APIs (optional) ----------------------------
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
ABUSEIPDB_API_KEY=

# --- AI PROVIDERS (optional) ----------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- EMAIL / SMTP (optional) ----------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- SECURITY -------------------------------------------------------
ENCRYPTION_KEY=
